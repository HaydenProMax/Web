{
  "name": "hayden-web-workstation",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "node scripts/dev-web.mjs",
    "dev:fast": "pnpm --filter web exec next dev --turbopack",
    "build": "corepack pnpm --filter web build",
    "start": "corepack pnpm --filter web start",
    "lint": "corepack pnpm --filter web lint",
    "typecheck": "corepack pnpm --filter web typecheck",
    "regression:web:start": "node scripts/start-regression-web.mjs",
    "regression:web:stop": "node scripts/stop-regression-web.mjs",
    "regression:web:status": "node scripts/status-regression-web.mjs",
    "db:generate": "corepack pnpm --filter web prisma generate",
    "db:migrate": "corepack pnpm --filter web prisma migrate dev",
    "db:seed": "node prisma/seed.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
